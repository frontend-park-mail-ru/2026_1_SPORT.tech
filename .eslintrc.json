{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "globals": {
    "Handlebars": "readonly",
    "NodeJS": "readonly"
  },
  "extends": [],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "rules": {
    "no-console": "off",
    "no-undef": "off",
    "no-useless-catch": "off",
    "no-unused-vars": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "quotes": ["error", "single"],
    "semi": ["error", "always"]
  }
}
