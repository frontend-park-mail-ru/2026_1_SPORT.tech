<div class="input-field input-field--{{state}} input-field--{{type}}" id="input-{{id}}-container">
    {{#if label}}
        <label class="input-field__label" for="{{id}}">{{label}}</label>
    {{/if}}
    
    <div class="input-field__wrapper">
        {{#if icon}}
            <span class="input-field__icon">{{{icon}}}</span>
        {{/if}}
        
        <input 
            type="{{inputType}}" 
            id="{{id}}"
            class="input-field__input" 
            placeholder="{{placeholder}}"
            value="{{value}}"
            {{#if disabled}}disabled{{/if}}
            {{#if readonly}}readonly{{/if}}
            {{#if required}}required{{/if}}
            {{#if maxlength}}maxlength="{{maxlength}}"{{/if}}
            {{#if autocomplete}}autocomplete="{{autocomplete}}"{{/if}}
        >
        
        {{#if showEye}}
        <button 
            class="input-field__eye input-field__eye--{{eyeState}}" 
            type="button"
            aria-label="{{#if isPasswordVisible}}Скрыть пароль{{else}}Показать пароль{{/if}}"
        >
            {{#if isPasswordVisible}}
                {{! Open Eye Icon }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" stroke-width="2"/>
                    <circle cx="12" cy="12" r="3" stroke-width="2"/>
                </svg>
            {{else}}
                {{! Closed Eye Icon }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
                    <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" stroke-width="2"/>
                    <line x1="1" y1="1" x2="23" y2="23" stroke-width="2"/>
                </svg>
            {{/if}}
        </button>
        {{/if}}
    </div>
    
    {{#if message}}
        <span class="input-field__message">{{message}}</span>
    {{/if}}
</div>
