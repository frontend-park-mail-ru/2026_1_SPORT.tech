<aside class="sidebar">
  <div class="sidebar__logo">
    <div class="sidebar__logo-icon">
      <svg viewBox="0 0 40 40" fill="none">
        <path d="M20 5L25 15H15L20 5Z" fill="#E85A2B"/>
        <circle cx="20" cy="25" r="8" fill="#E85A2B"/>
      </svg>
    </div>
    <div>
      <div class="sidebar__logo-text">SPORTEON</div>
      <div class="sidebar__logo-subtext">by SPORTtech</div>
    </div>
  </div>
  
  <nav class="sidebar__nav">
    {{#each navItems}}
    <a href="{{url}}" class="sidebar__nav-item {{#if active}}sidebar__nav-item--active{{/if}}" data-page="{{id}}">
      {{{icon}}}
      <span class="sidebar__nav-text">{{label}}</span>
    </a>
    {{/each}}
  </nav>
  
  <div class="sidebar__users">
    <div class="sidebar__users-title">Подписки</div>
    {{#each users}}
    <div class="sidebar__user-item" data-user-id="{{id}}">
      <div class="sidebar__user-avatar">
        {{#if avatar}}
          <img src="{{avatar}}" alt="{{name}}">
        {{else}}
          {{initials}}
        {{/if}}
      </div>
      <div class="sidebar__user-info">
        <div class="sidebar__user-name">{{name}}</div>
        <div class="sidebar__user-role">{{role}}</div>
      </div>
    </div>
    {{/each}}
  </div>
  
  <div class="sidebar__current-user">
    <div class="sidebar__current-user-avatar">
      {{#if currentUser.avatar}}
        <img src="{{currentUser.avatar}}" alt="{{currentUser.name}}">
      {{else}}
        {{currentUser.initials}}
      {{/if}}
    </div>
    <div class="sidebar__user-info">
      <div class="sidebar__user-name">{{currentUser.name}}</div>
      <div class="sidebar__user-role">{{currentUser.role}}</div>
    </div>
    <div class="sidebar__current-user-menu">
      <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
        <circle cx="12" cy="6" r="2"/>
        <circle cx="12" cy="12" r="2"/>
        <circle cx="12" cy="18" r="2"/>
      </svg>
    </div>
  </div>
</aside>