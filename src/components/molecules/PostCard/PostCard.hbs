<article class="post-card" data-post-id="{{post_id}}">
  {{#if sportType}}
  <span class="post-card__sport-badge">{{sportType}}</span>
  {{/if}}

  <div class="post-card__header">
    <div class="post-card__author-avatar">
      {{#if authorAvatar}}
        <img src="{{authorAvatar}}" alt="{{authorName}}" style="width:100%;height:100%;object-fit:cover;">
      {{else}}
        {{authorInitials}}
      {{/if}}
    </div>
    <div class="post-card__author-info">
      <div class="post-card__author-name">{{authorName}}</div>
      <div class="post-card__author-role">{{authorRole}}</div>
    </div>
    {{#if minTierId}}
    <span class="post-card__tier-badge" title="Только для подписчиков {{minTierId}} уровня">
      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z"/></svg>
      {{minTierId}} ур.
    </span>
    {{/if}}
  </div>

  <h3 class="post-card__title">{{title}}</h3>

  <!-- Короткая версия -->
  <div class="post-card__body post-card__body--short">
    <div class="post-card__content">{{{content}}}</div>
    <button type="button" class="post-card__expand-btn" data-post-expand>
      Читать далее
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
  </div>

  <!-- Полная версия -->
  <div class="post-card__body post-card__body--full" style="display:none;">
    <div class="post-card__content">{{{fullContent}}}</div>
    {{#if attachments.length}}
    <div class="post-card__attachments">
      {{#each attachments}}
      <div class="post-card__attachment">
        {{#if (eq kind "image")}}<img src="{{file_url}}" alt="" loading="lazy">{{/if}}
        {{#if (eq kind "video")}}<video controls src="{{file_url}}"></video>{{/if}}
      </div>
      {{/each}}
    </div>
    {{/if}}
    <button type="button" class="post-card__collapse-btn" data-post-collapse style="display:none;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><polyline points="18 15 12 9 6 15"/></svg>
      Свернуть
    </button>
  </div>

  <div class="post-card__footer">
    <button type="button" class="post-card__action post-card__action--like {{#if liked}}post-card__action--liked{{/if}}" data-post-like aria-pressed="{{liked}}">
      <svg viewBox="0 0 24 24" fill="{{#if liked}}currentColor{{else}}none{{/if}}" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <span data-post-like-count>{{likes}}</span>
    </button>
    <div class="post-card__action post-card__action--comments">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
      <span>{{comments}}</span>
    </div>
    <div class="post-card__actions-right">
      {{#if isOwner}}
      <button type="button" class="post-card__icon-btn" data-post-edit title="Редактировать"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg></button>
      <button type="button" class="post-card__icon-btn" data-post-delete title="Удалить"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
      {{/if}}
      <button type="button" class="post-card__icon-btn" data-post-share title="Поделиться"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg></button>
    </div>
  </div>
</article>
