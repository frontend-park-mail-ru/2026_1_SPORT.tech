<div class="profile-header">
  <div class="profile-header__cover">
    <div class="profile-header__cover-pattern"></div>
  </div>
  
  <div class="profile-header__info">
    <div class="profile-header__avatar-wrapper">
      <div class="profile-header__avatar">
        {{#if avatar}}
          <img src="{{avatar}}" alt="{{name}}">
        {{else}}
          {{initials}}
        {{/if}}
      </div>
      {{#if isOwnProfile}}
      <button class="profile-header__camera-btn" title="Сменить фото">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
          <circle cx="12" cy="13" r="4"/>
        </svg>
      </button>
      {{/if}}
    </div>
    
    <div class="profile-header__details">
      <h1 class="profile-header__name">{{name}}</h1>
      <p class="profile-header__role">{{role}}</p>
    </div>
    
    <div class="profile-header__actions">
      <span class="profile-header__actions-slot" id="profile-donate-{{id}}"></span>
      <span class="profile-header__actions-slot" id="profile-actions-{{id}}"></span>
    </div>
  </div>
  
  <div class="profile-header__stats">
    <button class="profile-header__stat" id="stat-btn-{{id}}" data-action="statistics">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 3v18h18"/>
        <path d="M18 17V9"/>
        <path d="M13 17V5"/>
        <path d="M8 17v-3"/>
      </svg>
      <span>Статистика</span>
    </button>
    <button class="profile-header__stat" id="subscriptions-btn-{{id}}" data-action="subscriptions">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      <span>Подписки</span>
    </button>
  </div>
</div>
