<div class="profile-header">
  <div class="profile-header__main">
    <div class="profile-header__avatar-wrapper">
      <div class="profile-header__avatar">
        {{#if avatar}}
          <img src="{{avatar}}" alt="{{name}}">
        {{else}}
          {{initials}}
        {{/if}}
      </div>
      {{#if isOwnProfile}}
      <button class="profile-header__camera-btn" title="Сменить фото">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/>
          <circle cx="12" cy="13" r="4"/>
        </svg>
      </button>
      {{/if}}
    </div>

    <div class="profile-header__body">
      <h1 class="profile-header__name" title="{{name}}">{{name}}</h1>

      <div class="profile-header__meta" id="profile-meta-{{id}}"></div>

      {{#if bio}}
      <div class="profile-header__bio">
        <p class="profile-header__bio-text" id="profile-bio-text-{{id}}">{{bio}}</p>
        <button type="button" class="profile-header__bio-toggle" id="profile-bio-toggle-{{id}}" hidden>ещё</button>
      </div>
      {{/if}}

      <div class="profile-header__actions">
        <span class="profile-header__actions-slot" id="profile-subscribe-{{id}}"></span>
        <span class="profile-header__actions-slot" id="profile-donate-{{id}}"></span>
        <span class="profile-header__actions-slot" id="profile-edit-{{id}}"></span>
        <span class="profile-header__actions-slot" id="profile-secondary-{{id}}"></span>
      </div>
    </div>
  </div>
</div>
