<div class="tiers-modal-backdrop" data-action="close"></div>

<div class="tiers-modal-panel">
  <div class="tiers-modal-header">
    <h2 class="tiers-modal-title">Настройка уровней подписки</h2>
    <button
      class="tiers-modal-close-btn"
      data-action="close"
      aria-label="Закрыть"
    >×</button>
  </div>

  <div class="tiers-list" data-container="tiers-list">
    {{#if loading}}
      <div class="tiers-loading" role="status" aria-live="polite">
        <span class="tiers-loading__spinner" aria-hidden="true"></span>
        <span class="tiers-loading__text">Загрузка уровней...</span>
      </div>
    {{else if tiers.length}}
      {{#each tiers}}
        <div class="tier-card" data-tier-id="{{this.id}}">
          <div class="tier-card-header">
            <span class="tier-card-index">Уровень {{this.index}}</span>
            <button
              class="tier-remove-btn"
              data-action="remove-tier"
              data-tier-id="{{this.id}}"
              aria-label="Удалить уровень"
            >×</button>
          </div>

          <div class="tier-card-fields">
            <div class="tier-field">
              <label class="tier-field-label" for="tier-name-{{this.id}}">Название</label>
              <input
                id="tier-name-{{this.id}}"
                type="text"
                class="tier-input tier-name-input"
                data-tier-id="{{this.id}}"
                data-field="name"
                value="{{this.name}}"
                placeholder="Например: Базовый"
                maxlength="60"
                required
              >
            </div>

            <div class="tier-field">
              <label class="tier-field-label" for="tier-price-{{this.id}}">Цена (₽/мес)</label>
              <input
                id="tier-price-{{this.id}}"
                type="number"
                class="tier-input tier-price-input"
                data-tier-id="{{this.id}}"
                data-field="price"
                value="{{this.price}}"
                placeholder="0"
                min="0"
                max="1000000"
                step="1"
                inputmode="numeric"
                required
              >
            </div>

            <div class="tier-field">
              <label class="tier-field-label" for="tier-desc-{{this.id}}">Описание</label>
              <input
                id="tier-desc-{{this.id}}"
                type="text"
                class="tier-input tier-desc-input"
                data-tier-id="{{this.id}}"
                data-field="description"
                value="{{this.description}}"
                placeholder="Что получает подписчик"
                maxlength="500"
              >
            </div>

            <div class="tier-field tier-field--chat">
              <label class="tier-chat-toggle">
                <input
                  type="checkbox"
                  class="tier-input tier-chat-input"
                  data-tier-id="{{this.id}}"
                  data-field="chat_enabled"
                  {{#if this.chat_enabled}}checked{{/if}}
                >
                <span class="tier-chat-toggle__label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                  </svg>
                  Открыть чат с тренером
                </span>
              </label>
            </div>

            <div class="tier-field tier-field--chat">
              <label class="tier-chat-toggle">
                <input
                  type="checkbox"
                  class="tier-input tier-chat-input"
                  data-tier-id="{{this.id}}"
                  data-field="calendar_enabled"
                  {{#if this.calendar_enabled}}checked{{/if}}
                >
                <span class="tier-chat-toggle__label">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                  </svg>
                  Запись в календарь
                </span>
              </label>
            </div>
          </div>
        </div>
      {{/each}}
    {{else}}
      <p class="tiers-empty-message">Нет созданных уровней</p>
    {{/if}}
  </div>

  <button
    class="tiers-add-btn"
    data-action="add-tier"
    type="button"
    {{#if loading}}disabled{{/if}}
  >+ Добавить уровень</button>

  <div class="tiers-actions">
    <button
      class="tiers-cancel-btn"
      data-action="close"
      type="button"
    >Отмена</button>
    <button
      class="tiers-save-btn"
      data-action="save"
      type="button"
      {{#if loading}}disabled{{/if}}
    >Сохранить</button>
  </div>
</div>
