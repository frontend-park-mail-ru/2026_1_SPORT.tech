<div class="home-page">
  <div class="home-page__sidebar" id="sidebar-container"></div>

  <main class="home-page__main">
    <section class="home-page__hero">
      <div class="home-page__eyebrow">Каталог тренеров</div>
      <h1 class="home-page__title">Найдите тренера под свою цель</h1>
      <p class="home-page__description">
        Выберите специалиста, откройте его профиль и посмотрите специализацию, стаж и публикации.
      </p>
    </section>

    <section class="home-page__catalog">
      <div class="home-page__catalog-header">
        <div>
          <h2 class="home-page__catalog-title">Тренеры</h2>
          <p class="home-page__catalog-description">Нажмите на карточку, чтобы перейти в профиль тренера.</p>
        </div>
      </div>

      <!-- Поиск и фильтры -->
      <div class="home-page__toolbar">
        <div class="home-page__search">
          <span class="home-page__search-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </span>
          <input type="text" class="home-page__search-input" placeholder="Поиск по имени...">
        </div>
        <div class="home-page__filters" id="filters-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
          <span>Фильтры</span>
        </div>
      </div>

      <!-- Выпадающий список фильтров (скрыт) -->
      <div class="home-page__filters-dropdown" id="filters-dropdown" hidden>
        <h4 class="home-page__filters-title">Вид спорта</h4>
        <div id="sport-checkboxes"></div>
      </div>

      <div class="home-page__grid" id="trainers-grid"></div>
      <div class="home-page__empty" id="trainers-empty" hidden>
        <p>Пока нет доступных тренеров</p>
      </div>
    </section>
  </main>
</div>
