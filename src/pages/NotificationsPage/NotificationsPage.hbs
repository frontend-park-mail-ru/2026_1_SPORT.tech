<div class="notifications-page">
  <div class="notifications-page__sidebar" id="sidebar-container"></div>
  <div class="notifications-page__main">
    <div class="notifications-page__header">
      <h1 class="notifications-page__title">Уведомления</h1>
      <button class="notifications-page__mark-read" data-mark-all-read>Отметить все прочитанными</button>
    </div>
    <div class="notifications-page__list" id="notifications-list"></div>
    <div class="notifications-page__empty" id="notifications-empty" hidden>
      <p>Нет новых уведомлений</p>
    </div>
  </div>
</div>
